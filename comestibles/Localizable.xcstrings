        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"%@\" y todos los artículos relacionados se eliminarán permanentemente."
          }
        }
      }
    },
    "%@ (%lld)" : {
      "comment" : "A title that shows the name of the location and the number of filtered items.",
