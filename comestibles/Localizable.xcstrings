    "?" : {
      "comment" : "A placeholder text that is displayed in the location row item when there is no image.",
      "isCommentAutoGenerated" : true
    },
    "\"%@\" und alle zugehörigen Artikel werden unwiderruflich gelöscht." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"%@\" und alle zugehörigen Artikel werden unwiderruflich gelöscht."
